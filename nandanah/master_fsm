`timescale 1ns / 1ps

module master_fsm(
    input clk,
    input reset,
    input start,

    input stage1_done,
    input stage1_fail,

    input stage2_done,

    input stage3_done,
    input stage3_fail,

    input time_up,

    output reg enable_stage1,
    output reg enable_stage2,
    output reg enable_stage3,

    output reg game_win,
    output reg game_over
);

    // State Encoding
    parameter IDLE      = 3'b000;
    parameter STAGE1    = 3'b001;
    parameter STAGE2    = 3'b010;
    parameter STAGE3    = 3'b011;
    parameter ESCAPED   = 3'b100;
    parameter GAME_OVER = 3'b101;

    reg [2:0] current_state;
    reg [2:0] next_state;

    // State Register
    always @(posedge clk or posedge reset)
    begin
        if(reset)
            current_state <= IDLE;
        else
            current_state <= next_state;
    end

    // Next-State Logic
    always @(*)
    begin
        next_state = current_state;

        case(current_state)

            IDLE:
            begin
                if(start)
                    next_state = STAGE1;
            end

            STAGE1:
            begin
                if(time_up || stage1_fail)
                    next_state = GAME_OVER;
                else if(stage1_done)
                    next_state = STAGE2;
            end

            STAGE2:
            begin
                if(time_up)
                    next_state = GAME_OVER;
                else if(stage2_done)
                    next_state = STAGE3;
            end

            STAGE3:
            begin
                if(time_up || stage3_fail)
                    next_state = GAME_OVER;
                else if(stage3_done)
                    next_state = ESCAPED;
            end

            ESCAPED:
                next_state = ESCAPED;

            GAME_OVER:
                next_state = GAME_OVER;

            default:
                next_state = IDLE;

        endcase
    end

    // Output Logic
    always @(*)
    begin
        enable_stage1 = 0;
        enable_stage2 = 0;
        enable_stage3 = 0;
        game_win      = 0;
        game_over     = 0;

        case(current_state)

            IDLE:
            begin
            end

            STAGE1:
                enable_stage1 = 1;

            STAGE2:
                enable_stage2 = 1;

            STAGE3:
                enable_stage3 = 1;

            ESCAPED:
                game_win = 1;

            GAME_OVER:
                game_over = 1;

        endcase
    end

endmodule
