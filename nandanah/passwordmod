`timescale 1ns / 1ps

module password_stage(

    input clk,
    input reset,
    input enable,

    input submit,
    input time_up,

    input A,
    input B,
    input C,
    input D,

    output reg [2:0] count,
    output reg fully_correct,

    output reg stage1_done,
    output reg stage1_fail,
    output reg penalty_pulse,

    output reg [2:0] guess_count

);

parameter MAX_GUESSES = 5;

// Combinational Password Comparison
always @(*)
begin
    count = 0;

    if(A == 1)
        count = count + 1;

    if(B == 0)
        count = count + 1;

    if(C == 1)
        count = count + 1;

    if(D == 1)
        count = count + 1;

    if(count == 4)
        fully_correct = 1;
    else
        fully_correct = 0;
end

// Stage Controller
always @(posedge clk or posedge reset)
begin

    if(reset)
    begin
        guess_count <= 0;
        stage1_done <= 0;
        stage1_fail <= 0;
        penalty_pulse <= 0;
    end

    else if(enable)
    begin

        // Default: penalty is a one-clock pulse
        penalty_pulse <= 0;

        // Time expired
        if(time_up)
        begin
            stage1_fail <= 1;
        end

        // User presses Submit
        else if(submit)
        begin

            // Correct password
            if(fully_correct)
            begin
                stage1_done <= 1;
            end

            // Wrong password
            else
            begin

                guess_count <= guess_count + 1;

                penalty_pulse <= 1;

                if(guess_count == MAX_GUESSES-1)
                    stage1_fail <= 1;

            end

        end

    end

end

endmodule
