module module_1(
    input [3:0] Key,
    input [3:0] Guess,
    output [2:0] pos,
    input reset,
    input clk,
    output stage1_done,
    output stage1_fail,
    output penalty
);
    parameter GUESS=2'd0, CHECK=2'd1, CORRECT=2'd2, INCORRECT=2'd3;
    reg [2:0] state, next;
    reg [2:0] lives=3'd3;
    reg [2:0] pen_tally=3'd0;

    // XNOR bits to count matches
    wire [3:0] match_no = Key ~^ Guess;
    
    // Explicitly add the bits to find how many match
    assign pos = match_no[0] + match_no[1] + match_no[2] + match_no[3];

    // Combinatorial Logic
    always @(*) begin
        case (state)
            GUESS: begin
                // If the user hasn't typed anything yet, stay in guess
                if (Guess == 4'b0000) begin
                    next = GUESS;
                end
                // If they typed a guess, move to check it
                else begin
                    next = CHECK;
                end
            end
            CHECK: begin
                next = (pos == 3'd4) ? CORRECT : INCORRECT;
            end
            INCORRECT: begin
                next = (lives > 0) ? GUESS : INCORRECT;
            end
            CORRECT: begin
                next = CORRECT;
            end
            default: next = GUESS;
        endcase
    end

    // Sequential Logic
    always @(posedge clk) begin
        if (reset) begin
            state <= GUESS;
            lives <= 3'd3;
        end else begin
            state <= next;
            if(state==INCORRECT) begin
                lives<=(lives>0)?(lives-1):(3'd0);
                pen_tally<=pen_tally+3'd1;
                 end

        end
    end

    assign stage1_done = (state == CORRECT&& pos==3'd4);
    assign stage1_fail = (lives == 3'd0 && state == INCORRECT);
    assign penalty     = (state==INCORRECT && reset==0);

endmodule
