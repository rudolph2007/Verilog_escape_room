module x1(
    input clk,
    input reset,
    input enable,

    input submit,
    input [3:0] guess,

    output reg stage1_done,
    output reg stage1_fail,
    output reg penalty_pulse,

    output reg [2:0] match_count,
    output reg [2:0] attempts_left
);

parameter PASSWORD = 4'b1010;

localparam WAIT_GUESS = 2'd0;
localparam CHECK      = 2'd1;
localparam SUCCESS    = 2'd2;
localparam FAIL       = 2'd3;

reg [1:0] state, next_state;

reg [2:0] attempts_used;

wire full_match;

assign full_match = (guess == PASSWORD);


// Match Counter
always @(*) begin
    match_count = 0;

    if(guess[0] == PASSWORD[0])
        match_count = match_count + 1;

    if(guess[1] == PASSWORD[1])
        match_count = match_count + 1;

    if(guess[2] == PASSWORD[2])
        match_count = match_count + 1;

    if(guess[3] == PASSWORD[3])
        match_count = match_count + 1;
end


// State Register
always @(posedge clk or posedge reset) begin

    if(reset)
        state <= WAIT_GUESS;

    else if(enable)
        state <= next_state;

end


// Attempt Counter
always @(posedge clk or posedge reset) begin

    if(reset)
        attempts_used <= 0;

    else if(enable &&
            state == CHECK &&
            !full_match &&
            attempts_used < 5)
    begin
        attempts_used <= attempts_used + 1;
    end

end


// Next State Logic
always @(*) begin

    next_state = state;

    case(state)

        WAIT_GUESS:
        begin
            if(submit)
                next_state = CHECK;
        end

        CHECK:
        begin
            if(full_match)
                next_state = SUCCESS;

            // 5th wrong attempt
            else if(attempts_used == 4)
                next_state = FAIL;

            else
                next_state = WAIT_GUESS;
        end

        SUCCESS:
            next_state = SUCCESS;

        FAIL:
            next_state = FAIL;

        default:
            next_state = WAIT_GUESS;

    endcase

end


// Outputs
always @(*) begin

    stage1_done   = 0;
    stage1_fail   = 0;
    penalty_pulse = 0;

    case(state)

        WAIT_GUESS:
        begin
            stage1_done   = 0;
            stage1_fail   = 0;
        end

        CHECK:
        begin
            if(!full_match)
                penalty_pulse = 1;
        end

        SUCCESS:
        begin
            stage1_done = 1;
        end

        FAIL:
        begin
            stage1_fail = 1;
        end

    endcase

end


// Attempts Remaining
always @(*) begin
    attempts_left = 5 - attempts_used;
end

endmodule
